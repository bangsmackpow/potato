{
  "name": "spud-buds-cookbook",
  "version": "1.0.0",
  "description": "A children's potato cookbook - printable recipes for kids",
  "main": "src/index.ts",
  "scripts": {
    "build": "echo 'No build step needed for Workers'",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply spud-buds-db",
    "db:local": "wrangler d1 migrations apply spud-buds-db --local",
    "format": "prettier --write .",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/zod-validator": "^0.4.0",
    "zod": "^3.23.0",
    "stripe": "^16.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.6.0",
    "wrangler": "^4.81.1",
    "prettier": "^3.3.0",
    "eslint": "^9.13.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
