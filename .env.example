# Environment Variables for Spud Buds Cookbook
# Copy this file to .env.local for local development
# NEVER commit .env.local to git!

# Cloudflare D1 Database
# Get this from: wrangler d1 create spud-buds-db
D1_DATABASE_ID=your-database-id-here

# Cloudflare R2 Bucket
# Get this from: wrangler r2 bucket create spud-buds-images
R2_BUCKET_NAME=spud-buds-images

# JWT Secret (generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID (create in Stripe Dashboard)
# Product: "Spud Buds Premium"
# Price: $10/year recurring
PREMIUM_PRICE_ID=price_...

# Admin Configuration
ADMIN_EMAIL=your-email@example.com

# Optional: Email Service (Resend)
# Get from: https://resend.com
RESEND_API_KEY=re_...

# Development Settings
DEBUG=true
NODE_ENV=development
